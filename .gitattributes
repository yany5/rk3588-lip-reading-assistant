# Keep Linux scripts usable even when contributors edit on Windows.
* text=auto
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.txt text eol=lf
# Binary documents.
*.pdf binary
# Store large model binaries with Git LFS.
models/*.dat filter=lfs diff=lfs merge=lfs -text
models/*.rknn filter=lfs diff=lfs merge=lfs -text
models/*.onnx filter=lfs diff=lfs merge=lfs -text
models/*.rkllm filter=lfs diff=lfs merge=lfs -text
models/*.bin filter=lfs diff=lfs merge=lfs -text
